# Operator Engine — deployment environment.
# Copy to deployment/.env and fill in. NEVER commit real secrets.
#
# On the operator's own VM the self-hosted deploy runner reads this file from a
# fixed path — /opt/operator/.env (deploy.sh, OPERATOR_ENV_FILE). Put it there
# with chmod 600. See deployment/self-hosted-runner.md.

# Container image. Local dev can leave this unset (compose builds from source).
# Production: pin a pushed tag, e.g. ghcr.io/<owner>/<repo>/operator-engine:latest
# OPERATOR_IMAGE=ghcr.io/<owner>/<repo>/operator-engine:latest

# Logging: info | debug | warn
LOG_LEVEL=info

# Graceful-shutdown drain budget in ms. Keep <= compose stop_grace_period.
SHUTDOWN_GRACE_MS=300000

# --- Secrets --------------------------------------------------------------
# GitHub token for the managed repo(s). The name must match `tokenEnvVar`
# in config/repos.yaml.
MANAGED_REPO_GH_TOKEN=

# Agent-provider auth (whichever engine/content/defaults/agents.yaml uses).
# ANTHROPIC_API_KEY — analysis/review roles (Claude). Required.
ANTHROPIC_API_KEY=
# CURSOR_API_KEY — code-writing roles (Cursor Composer). Required by the
# current agents.yaml (creator/improver/supervisor run on Cursor).
CURSOR_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=
# OPENROUTER_API_KEY=
